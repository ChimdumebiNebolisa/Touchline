[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ClubDashboard.cs" id="1"]

[node name="ClubDashboard" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Panel" type="VBoxContainer" parent="Center"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Heading" type="Label" parent="Center/Panel"]
layout_mode = 2
text = "Club Dashboard"
horizontal_alignment = 1

[node name="ClubContextLabel" type="Label" parent="Center/Panel"]
layout_mode = 2
text = "No club selected yet."
autowrap_mode = 3
horizontal_alignment = 1

[node name="StubMessage" type="Label" parent="Center/Panel"]
layout_mode = 2
text = "Step 4 will expand this dashboard with squad, fixtures, standings, and matchday context."
autowrap_mode = 3
horizontal_alignment = 1

[node name="SquadButton" type="Button" parent="Center/Panel"]
layout_mode = 2
text = "Squad"

[node name="TacticsButton" type="Button" parent="Center/Panel"]
layout_mode = 2
text = "Tactics"

[node name="FixturesButton" type="Button" parent="Center/Panel"]
layout_mode = 2
text = "Fixtures"

[node name="StandingsButton" type="Button" parent="Center/Panel"]
layout_mode = 2
text = "Standings"

[node name="MatchdayButton" type="Button" parent="Center/Panel"]
layout_mode = 2
text = "Matchday"

[node name="BackButton" type="Button" parent="Center/Panel"]
layout_mode = 2
text = "Back to Choose Club"

[connection signal="pressed" from="Center/Panel/SquadButton" to="." method="OnSquadPressed"]
[connection signal="pressed" from="Center/Panel/TacticsButton" to="." method="OnTacticsPressed"]
[connection signal="pressed" from="Center/Panel/FixturesButton" to="." method="OnFixturesPressed"]
[connection signal="pressed" from="Center/Panel/StandingsButton" to="." method="OnStandingsPressed"]
[connection signal="pressed" from="Center/Panel/MatchdayButton" to="." method="OnMatchdayPressed"]
[connection signal="pressed" from="Center/Panel/BackButton" to="." method="OnBackPressed"]
