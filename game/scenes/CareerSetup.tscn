[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/CareerSetup.cs" id="1"]

[node name="CareerSetup" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Panel" type="VBoxContainer" parent="Center"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Heading" type="Label" parent="Center/Panel"]
layout_mode = 2
text = "Career Setup"
horizontal_alignment = 1

[node name="ManagerNameLabel" type="Label" parent="Center/Panel"]
layout_mode = 2
text = "Manager Name"

[node name="ManagerNameInput" type="LineEdit" parent="Center/Panel"]
layout_mode = 2
placeholder_text = "Enter manager name"
text = "Alex Mercer"

[node name="SeedLabel" type="Label" parent="Center/Panel"]
layout_mode = 2
text = "Career Seed"

[node name="SeedInput" type="SpinBox" parent="Center/Panel"]
layout_mode = 2
min_value = 1.0
max_value = 999999.0
step = 1.0
value = 20260408.0

[node name="StartCareerButton" type="Button" parent="Center/Panel"]
layout_mode = 2
text = "Start Career"

[node name="StatusLabel" type="Label" parent="Center/Panel"]
layout_mode = 2
text = "Career state will initialize here before club selection."
autowrap_mode = 3
horizontal_alignment = 1

[node name="BackButton" type="Button" parent="Center/Panel"]
layout_mode = 2
text = "Back to Main Menu"

[connection signal="pressed" from="Center/Panel/StartCareerButton" to="." method="OnStartCareerPressed"]
[connection signal="pressed" from="Center/Panel/BackButton" to="." method="OnBackPressed"]
