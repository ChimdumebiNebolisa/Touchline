[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ChooseClub.cs" id="1"]

[node name="ChooseClub" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Panel" type="VBoxContainer" parent="Center"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="Heading" type="Label" parent="Center/Panel"]
layout_mode = 2
text = "Choose Club"
horizontal_alignment = 1

[node name="CareerSummaryLabel" type="Label" parent="Center/Panel"]
layout_mode = 2
text = "Career context unavailable."
autowrap_mode = 3
horizontal_alignment = 1

[node name="StubMessage" type="Label" parent="Center/Panel"]
layout_mode = 2
text = "Step 3 will implement playable club selection from seeded data."
autowrap_mode = 3
horizontal_alignment = 1

[node name="ClubList" type="ItemList" parent="Center/Panel"]
layout_mode = 2
custom_minimum_size = Vector2(420, 180)

[node name="ConfirmSelectionButton" type="Button" parent="Center/Panel"]
layout_mode = 2
text = "Confirm Club Selection"

[node name="SelectionStatusLabel" type="Label" parent="Center/Panel"]
layout_mode = 2
text = "No club selected yet."
autowrap_mode = 3
horizontal_alignment = 1

[node name="BackButton" type="Button" parent="Center/Panel"]
layout_mode = 2
text = "Back to Career Setup"

[connection signal="pressed" from="Center/Panel/ConfirmSelectionButton" to="." method="OnConfirmSelectionPressed"]
[connection signal="pressed" from="Center/Panel/BackButton" to="." method="OnBackPressed"]
